<?xml version="1.0"?>
<robot xmlns:xacro="https://www.ros.org/wiki/xacro" name="robot">

    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>

    <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
    </material>

    <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
    </material>

    <link name="base_link"></link>
  
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0.0 0.0 0.065" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.3 0.2 0.05"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <joint name="left_wheel_1_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_1"/>
        <origin xyz="0.075 0.115 0.05" rpy="-${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 1.0"/>
        
    </joint>

    <link name="left_wheel_1">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="left_wheel_2_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_2"/>
        <origin xyz="-0.075 0.115 0.05" rpy="-${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 1.0"/>
        
    </joint>

    <link name="left_wheel_2">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="right_wheel_1_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_1"/>
        <origin xyz="0.075 -0.115 0.05" rpy="${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 -1.0"/>
        
    </joint>

    <link name="right_wheel_1">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="right_wheel_2_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_2"/>
        <origin xyz="-0.075 -0.115 0.05" rpy="${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 -1.0"/>
        
    </joint>

    <link name="right_wheel_2">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name='lidar_link' type="fixed">
        <parent link="base_link"/>
        <child link="lidar"/>
        <origin xyz="0.075 0.0 0.105" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="lidar">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

</robot>